NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the anon public key from Project Settings → API (JWT, role "anon").
# NEVER put the service_role secret here or in any NEXT_PUBLIC_* variable.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
# Optional alternative public key (sb_publishable_…). If BOTH anon and publishable
# are set, NEXT_PUBLIC_SUPABASE_ANON_KEY wins — a wrong anon value blocks publishable.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only (no NEXT_PUBLIC_ prefix). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Structured lease extraction (POST /api/analyse). Required for dates, obligations, snippets in the UI.
OPENAI_API_KEY=sk-...
# Optional — defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Optional — per-request timeout for OpenAI HTTP (ms). Default 180000 (3 minutes). Min 15000, max 600000.
# OPENAI_REQUEST_TIMEOUT_MS=180000

# Alert emails (Resend). https://resend.com/api-keys
RESEND_API_KEY=re_...
# Must be a verified sender in Resend (or use Resend onboarding domain in dev).
RESEND_FROM_EMAIL="LeaseLens <onboarding@resend.dev>"

# Base URL for links inside emails (production domain).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protect GET /api/cron/alerts (Vercel Cron sends Authorization: Bearer <CRON_SECRET> when configured in project env).
CRON_SECRET=generate_a_long_random_string
